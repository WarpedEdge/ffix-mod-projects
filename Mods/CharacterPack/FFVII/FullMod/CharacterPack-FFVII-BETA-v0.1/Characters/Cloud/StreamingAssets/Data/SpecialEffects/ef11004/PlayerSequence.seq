// Player sequence of SFX Cloud Focused Thrust

WaitAnimation: Char=Caster
Message: Text=[CastName] ; Priority=1 ; Title=True ; Reflect=True
LoadSFX: SFX=Lancer ; UseCamera=False
PlayAnimation: Char=Caster ; Anim=ANH_MAIN_CLOUD_00_BTL_PREP
WaitAnimation: Char=Caster
StartThread: Condition=AreCasterAndTargetsEnemies ; Sync=True
	PlayAnimation: Char=Caster ; Anim=ANH_MAIN_CLOUD_00_BTL_FOCUSED_THRUST ; Speed=1.5
	MoveToTarget: Char=Caster ; Target=AllTargets ; Distance=0 ; UseCollisionRadius=True ; Time=6
	Turn: Char=Caster ; BaseAngle=AllTargets ; Time=0
	WaitMove: Char=Caster
EndThread
StartThread: Condition=!AreCasterAndTargetsEnemies ; Sync=True
	MoveToTarget: Char=Caster ; Target=AllTargets ; Offset=(0.0, 0.0, 1600) ; Time=0
	Turn: Char=Caster ; BaseAngle=AllTargets ; Time=0
	PlayAnimation: Char=Caster ; Anim=ANH_MAIN_CLOUD_00_BTL_FOCUSED_THRUST ; Speed=1.5
	MoveToTarget: Char=Caster ; Target=AllTargets ; Distance=400 ; UseCollisionRadius=True ; Time=6
EndThread
WaitMove: Char=Caster
StartThread
	Wait: Time=1
	WaitSFXLoaded: SFX=Lancer
	PlaySFX: SFX=Lancer ; JumpToFrame=10

	WaitSFXDone: SFX=Lancer
EndThread
StartThread: Condition=AreCasterAndTargetsEnemies ; Sync=True
	MoveToPosition: Char=Caster ; AbsolutePosition=Default ; Anim=MP_BACK
	Turn: Char=Caster ; BaseAngle=Default ; Time=4
	WaitMove: Caster
EndThread
StartThread: Condition=!AreCasterAndTargetsEnemies ; Sync=True
	MoveToPosition: Char=Caster ; AbsolutePosition=Default ; Time=0
	Turn: Char=Caster ; BaseAngle=Default ; Time=0
EndThread
PlayAnimation: Char=Caster ; Anim=Idle
WaitTurn: Char=Caster
