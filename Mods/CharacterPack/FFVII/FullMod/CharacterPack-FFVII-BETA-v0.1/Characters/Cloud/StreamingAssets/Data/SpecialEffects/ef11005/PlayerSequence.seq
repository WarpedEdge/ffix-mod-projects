StartThread:
	Wait: Time=5
    LoadSFX: SFX=Fire_Sword ; Reflect=True ; UseCamera=False
    WaitSFXLoaded: SFX=Fire_Sword ; Reflect=True
    PlaySFX: SFX=Fire_Sword ; Reflect=True ; SkipSequence=True ; JumpToFrame=23
    Wait: Time=5
	
	PlaySound: Sound=138
	
EndThread
StartThread:
	Wait: Time=10
    LoadSFX: SFX=Thunder_Slash_1 ; Reflect=True ; UseCamera=False
    WaitSFXLoaded: SFX=Thunder_Slash_1 ; Reflect=True
    PlaySFX: SFX=Thunder_Slash_1 ; Reflect=True ; SkipSequence=True
	PlaySound: Sound=14
	PlaySound: Sound=4
	PlaySound: Sound=76
EndThread

