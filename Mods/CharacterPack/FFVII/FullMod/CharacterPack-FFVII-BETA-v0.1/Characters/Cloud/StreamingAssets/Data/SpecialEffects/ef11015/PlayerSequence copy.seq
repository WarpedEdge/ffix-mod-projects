// Player sequence of SFX Meteorain (4-6 hits)

WaitAnimation: Char=Caster
Message: Text=[CastName] ; Priority=1 ; Title=True ; Reflect=True
SetupReflect: Delay=SFXLoaded
StartThread: Condition=ItemUseId == 255 ; Sync=True
	PlayAnimation: Char=Caster ; Anim=MP_IDLE_TO_CHANT
	WaitAnimation: Char=Caster
	PlayAnimation: Char=Caster ; Anim=MP_CHANT ; Loop=True
	Channel
	Wait: Time=8
	StopChannel
	PlayAnimation: Char=Caster ; Anim=MP_MAGIC
	WaitAnimation: Char=Caster
EndThread
StartThread: Condition=ItemUseId != 255 ; Sync=True
	PlayAnimation: Char=Caster ; Anim=MP_ITEM1
	WaitAnimation: Char=Caster
EndThread

// 4-hits (34%)
StartThread: Condition=GetRandom(0, 100) < 34 ; Sync=True
	
	StartThread: Target=MatchingCondition(!IsPlayer && IsTargetable && HP>0) ; Sync=True
		StartThread: Target=RandomTarget ; Sync=True
			LoadSFX: SFX=Comet ; Reflect=True ; UseCamera=False
			WaitSFXLoaded: SFX=Comet ; Reflect=True
			PlaySFX: SFX=Comet ; Reflect=True
			Wait: Time=3
			Wait: Time=3
		EndThread
	EndThread
	StartThread: Target=MatchingCondition(!IsPlayer && IsTargetable && HP>0) ; Sync=True
		StartThread: Target=RandomTarget ; Sync=True
			LoadSFX: SFX=Comet ; Reflect=True ; UseCamera=False
			WaitSFXLoaded: SFX=Comet ; Reflect=True
			PlaySFX: SFX=Comet ; Reflect=True
			Wait: Time=3
			Wait: Time=3
		EndThread
	EndThread
	StartThread: Target=MatchingCondition(!IsPlayer && IsTargetable && HP>0) ; Sync=True
		StartThread: Target=RandomTarget ; Sync=True
			LoadSFX: SFX=Comet ; Reflect=True ; UseCamera=False
			WaitSFXLoaded: SFX=Comet ; Reflect=True
			PlaySFX: SFX=Comet ; Reflect=True
			Wait: Time=3
			Wait: Time=3
		EndThread
	EndThread
	StartThread: Target=MatchingCondition(!IsPlayer && IsTargetable && HP>0) ; Sync=True
		StartThread: Target=RandomTarget ; Sync=True
			LoadSFX: SFX=Comet ; Reflect=True ; UseCamera=False
			WaitSFXLoaded: SFX=Comet ; Reflect=True
			PlaySFX: SFX=Comet ; Reflect=True
			Wait: Time=3
			Wait: Time=3
		EndThread
	EndThread
EndThread
